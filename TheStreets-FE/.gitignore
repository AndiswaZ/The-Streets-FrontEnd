# ============================================================
# Angular + Standalone + SSR Friendly .gitignore
# For TheStreets-FE – Clean GitHub pushes
# ============================================================

# -------------------------
# Node + Angular output
# -------------------------
node_modules/
dist/
tmp/
out-tsc/
bazel-out/
.angular/
.angular/cache/

# Angular server-side build folders (SSR)
server/
server.tsbuildinfo
server/main.js
server/main.js.map

# -------------------------
# Logs / Diagnostics
# -------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------
# IDEs and Editors
# -------------------------
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Local history
.history/

# -------------------------
# Environment files
# -------------------------
# If you want to avoid pushing real API URLs or secrets:
# Uncomment these lines to ignore environment files in prod
# src/environments/environment.prod.ts
# src/environments/environment.ts

# -------------------------
# Misc
# -------------------------
.sass-cache/
connect.lock
coverage/
libpeerconnection.log
testem.log
typings/
.eslintcache

# -------------------------
# System files
# -------------------------
.DS_Store
Thumbs.db
